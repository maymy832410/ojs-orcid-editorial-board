msgstr "Journal"

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.member"
msgstr "Editorial board member"

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.orcid"
msgstr "ORCID iD"

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.warning"
msgstr "You will be asked to sign in to your personal ORCID account. The listing can only be removed when the ORCID account matches the ORCID iD on the card. This helps prevent false or malicious reports."

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.continue"
msgstr "Continue with ORCID"

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.matchedTitle"
msgstr "ORCID identity verified"

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.matchedBody"
msgstr "Your ORCID iD matches the editorial listing for {$memberName} at {$journalName}. If you do not serve on this board, you may now remove this listing from the public page."

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.confirmRemove"
msgstr "Confirm: I do not serve on this board"

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.removedTitle"
msgstr "Listing removed at your request"

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.removedBody"
msgstr "The editorial board listing associated with your ORCID iD has been hidden from the public page. The journal has been notified of your request."

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.mismatchTitle"
msgstr "ORCID account does not match this listing"

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.mismatchBody"
msgstr "The ORCID account you signed in with does not match the ORCID iD shown on this editorial listing. We cannot process this report. Check that you are signing in with the same ORCID iD displayed on the card."

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.expiredTitle"
msgstr "This report link has expired"

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.expiredBody"
msgstr "For security reasons, report links are time-limited. Please start the report process again from the editorial board page if you still wish to dispute this listing."

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.deniedTitle"
msgstr "ORCID access was not granted"

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.deniedBody"
msgstr "You declined to grant access to your ORCID account. Without ORCID authentication we cannot verify your identity or process your report."

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.errorTitle"
msgstr "Unable to process this report"

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.errorBody"
msgstr "An error occurred while processing this report. Please try again later or contact the journal if the issue persists."

