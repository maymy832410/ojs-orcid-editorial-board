msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.title"
msgstr "Report an Editorial Board Listing"

msgid "plugins.generic.orcidEditorialBoard.reportFalseClaim.subtitle"
msgstr "Use this process if you are the owner of the ORCID iD shown on the editorial card and you do not consent to be listed as an editor."

