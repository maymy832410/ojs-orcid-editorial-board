msgid "plugins.generic.orcidEditorialBoard.invitation.body"
msgstr "<div style=\"margin:0;padding:0;background:#f6f8fb;\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"background:#f6f8fb;padding:24px 0;\"><tr><td align=\"center\" style=\"padding:0 12px;\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"620\" style=\"max-width:620px;background:#ffffff;border:1px solid #e5e7eb;border-radius:14px;overflow:hidden;\"><tr><td style=\"background:linear-gradient(135deg,#0f172a,#1e293b);padding:22px 26px;\"><div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#ffffff;font-size:15px;opacity:.95;\">Editorial Board Invitation</div><div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#ffffff;font-size:20px;font-weight:700;line-height:1.3;margin-top:4px;\">{$journalName}</div></td></tr><tr><td style=\"padding:26px 26px 10px 26px;\"><div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#111827;font-size:18px;font-weight:700;\">Welcome to the Editorial Board</div><div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#374151;font-size:14px;line-height:1.7;margin-top:10px;\">Dear {$memberName},<br><br>You have been added to the editorial board of <strong>{$journalName}</strong> as <strong>{$memberRole}</strong>. Please review the details below and confirm your acceptance, or decline if this was made in error.</div></td></tr><tr><td style=\"padding:10px 26px;\"><div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;font-size:13px;font-weight:700;color:#334155;text-transform:uppercase;letter-spacing:.04em;margin-bottom:8px;\">Your Profile Information</div><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"background:#f8fafc;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;\">{$memberDetailsHtml}</table></div></td></tr><tr><td align=\"center\" style=\"padding:20px 26px 10px;\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"padding-right:10px;\"><a href=\"{$acceptUrl}\" style=\"display:inline-block;background:#16a34a;color:#ffffff;text-decoration:none;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;font-size:14px;font-weight:700;padding:12px 24px;border-radius:10px;\">✓ Accept &amp; Confirm</a></td><td><a href=\"{$denyUrl}\" style=\"display:inline-block;background:#f1f5f9;color:#dc2626;text-decoration:none;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;font-size:14px;font-weight:700;padding:12px 24px;border-radius:10px;border:1px solid #e2e8f0;\">✕ Decline</a></td></tr></table></td></tr><tr><td style=\"padding:14px 26px 22px;\"><div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#374151;font-size:13px;line-height:1.7;background:#f8fafc;border:1px solid #e5e7eb;border-radius:12px;padding:14px;\"><strong>What happens when you accept?</strong> By accepting, you consent to being listed on the editorial board and declare that you have no undisclosed conflicts of interest. You may also be asked to complete a full ORCID verification and COI declaration separately.</div></td></tr><tr><td style=\"padding:18px 26px;background:#f9fafb;border-top:1px solid #e5e7eb;\"><div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#6b7280;font-size:12px;line-height:1.65;\"><div><strong>{$footerLine1}</strong></div><div>{$footerLine2}</div><div>{$footerLine3}</div></div></td></tr></table></td></tr></table></div>"

