msgstr "Sent to a member confirming their invitation was declined and the journal has been informed."

msgid "plugins.generic.orcidEditorialBoard.denialConfirmation.subject"
msgstr "Your editorial board invitation has been declined — {$journalName}"

msgid "plugins.generic.orcidEditorialBoard.denialConfirmation.body"
msgstr "<div style=\"margin:0;padding:0;background:#f6f8fb;\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"background:#f6f8fb;padding:24px 0;\"><tr><td align=\"center\" style=\"padding:0 12px;\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"620\" style=\"max-width:620px;background:#ffffff;border:1px solid #e5e7eb;border-radius:14px;overflow:hidden;\"><tr><td style=\"background:linear-gradient(135deg,#7f1d1d,#991b1b);padding:22px 26px;\"><div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#ffffff;font-size:15px;opacity:.95;\">Invitation Declined</div><div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#ffffff;font-size:20px;font-weight:700;line-height:1.3;margin-top:4px;\">{$journalName}</div></td></tr><tr><td style=\"padding:26px 26px 10px;\"><div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#111827;font-size:18px;font-weight:700;\">Your request has been processed</div><div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#374151;font-size:14px;line-height:1.7;margin-top:10px;\">Dear {$memberName},<br><br>This email confirms that you have declined the invitation to serve on the editorial board of <strong>{$journalName}</strong>. Your listing has been removed from the public editorial board page, and the journal administration has been notified of your decision.<br><br>No further action is required on your part.</div></td></tr><tr><td style=\"padding:14px 26px 22px;\"><div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#374151;font-size:13px;line-height:1.7;background:#fef2f2;border:1px solid #fecaca;border-radius:12px;padding:14px;\"><strong>Changed your mind?</strong> If you declined by mistake, please contact the journal editor directly to be re-added to the board.</div></td></tr><tr><td style=\"padding:18px 26px;background:#f9fafb;border-top:1px solid #e5e7eb;\"><div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#6b7280;font-size:12px;line-height:1.65;\"><div><strong>{$footerLine1}</strong></div><div>{$footerLine2}</div><div>{$footerLine3}</div></div></td></tr></table></td></tr></table></div>"

