msgid "plugins.generic.orcidEditorialBoard.coiRequest.description"
msgstr "Email sent to editorial board members requesting a conflict-of-interest declaration."

msgid "plugins.generic.orcidEditorialBoard.coiRequest.subject"
msgstr "Conflict of Interest Declaration Required"

msgid "plugins.generic.orcidEditorialBoard.coiRequest.body"
msgstr "<div style=\"margin:0;padding:0;background:#f6f8fb;\">\n  <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"background:#f6f8fb;padding:24px 0;\">\n    <tr>\n      <td align=\"center\" style=\"padding:0 12px;\">\n        <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"620\" style=\"max-width:620px;background:#ffffff;border:1px solid #e5e7eb;border-radius:14px;overflow:hidden;\">\n          <tr>\n            <td style=\"background:linear-gradient(135deg,#111827,#334155);padding:22px 26px;\">\n              <div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#ffffff;font-size:15px;opacity:.95;\">Disclosure Request</div>\n              <div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#ffffff;font-size:20px;font-weight:700;line-height:1.3;margin-top:4px;\">{$journalName}</div>\n            </td>\n          </tr>\n          <tr>\n            <td style=\"padding:26px 26px 10px 26px;\">\n              <div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#111827;font-size:18px;font-weight:700;\">Conflict of Interest (COI) disclosure form</div>\n              <div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#374151;font-size:14px;line-height:1.7;margin-top:10px;\">\n                Dear {$memberName},<br><br>\n                As a member of the editorial board of <strong>{$journalName}</strong>, we kindly ask you to complete a conflict-of-interest disclosure. This supports transparency and editorial integrity.\n              </div>\n            </td>\n          </tr>\n          <tr>\n            <td align=\"center\" style=\"padding:18px 26px 18px 26px;\">\n              <a href=\"{$coiUrl}\" style=\"display:inline-block;background:#2563eb;color:#ffffff;text-decoration:none;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;font-size:14px;font-weight:700;padding:12px 18px;border-radius:10px;\">Open COI Disclosure Form</a>\n              <div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#6b7280;font-size:12px;line-height:1.6;margin-top:12px;\">\n                If the button does not work, copy and paste this link into your browser:<br>\n                <span style=\"word-break:break-all;\">{$coiUrl}</span>\n              </div>\n            </td>\n          </tr>\n          <tr>\n            <td style=\"padding:18px 26px;background:#f9fafb;border-top:1px solid #e5e7eb;\">\n              <div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#6b7280;font-size:12px;line-height:1.65;\">\n                <div><strong>{$footerLine1}</strong></div>\n                <div>{$footerLine2}</div>\n                <div>{$footerLine3}</div>\n              </div>\n            </td>\n          </tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n</div>"

