msgid "plugins.generic.orcidEditorialBoard.consentRequest.body"
msgstr "<div style=\"margin:0;padding:0;background:#f6f8fb;\">\n  <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"background:#f6f8fb;padding:24px 0;\">\n    <tr>\n      <td align=\"center\" style=\"padding:0 12px;\">\n        <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"620\" style=\"max-width:620px;background:#ffffff;border:1px solid #e5e7eb;border-radius:14px;overflow:hidden;\">\n          <tr>\n            <td style=\"background:linear-gradient(135deg,#0f172a,#1e293b);padding:22px 26px;\">\n              <div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#ffffff;font-size:15px;opacity:.95;\">Editorial Board Verification</div>\n              <div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#ffffff;font-size:20px;font-weight:700;line-height:1.3;margin-top:4px;\">{$journalName}</div>\n            </td>\n          </tr>\n          <tr>\n            <td style=\"padding:26px 26px 10px 26px;\">\n              <div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#111827;font-size:18px;font-weight:700;\">ORCID consent required</div>\n              <div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#374151;font-size:14px;line-height:1.7;margin-top:10px;\">\n                Dear {$memberName},<br><br>\n                You have been listed on the editorial board of <strong>{$journalName}</strong>. To confirm your awareness and consent, please sign in to your personal ORCID account and authorize this journal’s verification request.\n              </div>\n            </td>\n          </tr>\n          <tr>\n            <td align=\"center\" style=\"padding:18px 26px 18px 26px;\">\n              <a href=\"{$consentUrl}\" style=\"display:inline-block;background:#16a34a;color:#ffffff;text-decoration:none;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;font-size:14px;font-weight:700;padding:12px 18px;border-radius:10px;\">Verify via ORCID</a>\n              <div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#6b7280;font-size:12px;line-height:1.6;margin-top:12px;\">\n                If the button does not work, copy and paste this link into your browser:<br>\n                <span style=\"word-break:break-all;\">{$consentUrl}</span>\n              </div>\n            </td>\n          </tr>\n          <tr>\n            <td style=\"padding:0 26px 22px 26px;\">\n              <div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#374151;font-size:13px;line-height:1.7;background:#f8fafc;border:1px solid #e5e7eb;border-radius:12px;padding:14px 14px;\">\n                <strong>Why this matters:</strong> ORCID authentication can only be completed by the ORCID account owner. This helps prevent the listing of editorial board members without consent.\n              </div>\n            </td>\n          </tr>\n          <tr>\n            <td style=\"padding:18px 26px;background:#f9fafb;border-top:1px solid #e5e7eb;\">\n              <div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#6b7280;font-size:12px;line-height:1.65;\">\n                <div><strong>{$footerLine1}</strong></div>\n                <div>{$footerLine2}</div>\n                <div>{$footerLine3}</div>\n              </div>\n            </td>\n          </tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n</div>"

